{
  "servers": [
    {
      "name": "Confluence",
      "type": "http",
      "url": "https://davewai.atlassian.net/wiki/rest/api/content/753665?expand=body.storage",
      "auth": {
        "type": "basic",
        "username": "${{ env.CONFLUENCE_USERNAME}}"
        "password": "${{ env.CONFLUENCE_API_TOKEN }}"
      }
    },
    "confluence": {
      "command": "node",
      "args": ["/path/to/confluence_mcp/dist/index.js"],
      "env": {
        "CONFLUENCE_BASE_URL": "https://davewai.atlassian.net",
        "CONFLUENCE_USERNAME": "${{ env.CONFLUENCE_USERNAME }}",
        "CONFLUENCE_API_TOKEN": "${{ ENV.CONFLUENCE_API_TOKEN }}",
        "ALLOWED_SPACES": "SPACE1,SPACE2"
      }
    },
    "mcpServers": {
       "github": {
         "type": "http", // Or "local", "stdio", "sse"
         "url": "https://api.githubcopilot.com/mcp/", // The URL for the remote server
         "tools": ["*"] // Enables all tools available from the server
       }
    } 
  ]
}
